@model AspNetMvcProject.Models.Product

@{
    ViewData["Title"] = "Chỉnh sửa sản phẩm";
}

<div class="container mt-5">
    <div class="row justify-content-center">
        <div class="col-md-6">
            <div class="card border-0 shadow-lg">
                <div class="card-header bg-warning text-dark py-3">
                    <h3 class="mb-0 fw-bold">Chỉnh sửa sản phẩm</h3>
                </div>
                <div class="card-body p-4">
                    <form asp-action="Edit" enctype="multipart/form-data">
                        <div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>
                        <input type="hidden" asp-for="Id" />
                        
                        <div class="form-floating mb-3">
                            <input asp-for="Name" class="form-control" placeholder="Tên sản phẩm" />
                            <label asp-for="Name">Tên sản phẩm</label>
                            <span asp-validation-for="Name" class="text-danger small"></span>
                        </div>

                        <div class="form-floating mb-3">
                            <select asp-for="CategoryId" class="form-select" asp-items="ViewBag.CategoryId">
                                <option value="">-- Chọn danh mục --</option>
                            </select>
                            <label asp-for="CategoryId">Danh mục sản phẩm</label>
                        </div>

                        <!-- Hiển thị ảnh hiện tại -->
                        @if (Model.Images != null && Model.Images.Any())
                        {
                            <div class="mb-4">
                                <label class="form-label fw-bold text-secondary">Ảnh hiện tại (Chọn để xóa)</label>
                                <div class="row g-2">
                                    @foreach (var img in Model.Images)
                                    {
                                        <div class="col-3">
                                            <div class="position-relative border rounded overflow-hidden">
                                                <img src="@img.ImageUrl" class="img-fluid" style="height: 80px; width: 100%; object-fit: cover;" />
                                                <div class="position-absolute top-0 end-0 p-1">
                                                    <input type="checkbox" name="deleteImages" value="@img.Id" class="form-check-input bg-danger border-0 shadow-sm" />
                                                </div>
                                            </div>
                                        </div>
                                    }
                                </div>
                            </div>
                        }

                        <div class="mb-3">
                            <label class="form-label fw-bold text-secondary">Tải thêm ảnh mới</label>
                            <input type="file" name="newImages" class="form-control border-warning shadow-sm" multiple accept="image/*" />
                        </div>

                        <div class="form-floating mb-3">
                            <textarea asp-for="Description" class="form-control" style="height: 100px" placeholder="Mô tả"></textarea>
                            <label asp-for="Description">Mô tả</label>
                            <span asp-validation-for="Description" class="text-danger small"></span>
                        </div>

                        <div class="row">
                            <div class="col-md-6">
                                <div class="form-floating mb-3">
                                    <input asp-for="Price" class="form-control" type="number" step="0.01" placeholder="Giá" />
                                    <label asp-for="Price">Giá ($)</label>
                                    <span asp-validation-for="Price" class="text-danger small"></span>
                                </div>
                            </div>
                            <div class="col-md-6">
                                <div class="form-floating mb-3">
                                    <input asp-for="Stock" class="form-control" type="number" placeholder="Tồn kho" />
                                    <label asp-for="Stock">Tồn kho</label>
                                    <span asp-validation-for="Stock" class="text-danger small"></span>
                                </div>
                            </div>
                        </div>

                        <div class="d-grid gap-2 mt-4">
                            <button type="submit" class="btn btn-warning btn-lg shadow-sm fw-bold">Cập nhật</button>
                            <a asp-action="Index" class="btn btn-link text-secondary">Quay lại danh sách</a>
                        </div>
                    </form>
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    @{await Html.RenderPartialAsync("_ValidationScriptsPartial");}
}
