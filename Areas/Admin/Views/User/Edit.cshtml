@model AspNetMvcProject.Models.ApplicationUser

<div class="container mt-4">
    <div class="card shadow border-0">
        <div class="card-header bg-primary bg-gradient py-3">
            <h2 class="text-white text-center">Chỉnh sửa Người dùng</h2>
        </div>
        <div class="card-body p-4">
            <form method="post">
                <input asp-for="Id" hidden />
                <div class="mb-3">
                    <label class="form-label">Tên đăng nhập</label>
                    <input asp-for="Username" class="form-control" disabled />
                </div>
                <div class="mb-3">
                    <label asp-for="FullName" class="form-label">Họ và tên</label>
                    <input asp-for="FullName" class="form-control" />
                </div>
                <div class="mb-3">
                    <label asp-for="Email" class="form-label">Email</label>
                    <input asp-for="Email" class="form-control" />
                </div>
                <div class="mb-3">
                    <label asp-for="Address" class="form-label">Địa chỉ</label>
                    <input asp-for="Address" class="form-control" />
                </div>
                <div class="mb-3">
                    <label asp-for="Age" class="form-label">Tuổi</label>
                    <input asp-for="Age" class="form-control" />
                </div>
                <div class="row pt-2">
                    <div class="col-6">
                        <button type="submit" class="btn btn-primary form-control">Cập nhật</button>
                    </div>
                    <div class="col-6">
                        <a asp-action="Index" class="btn btn-outline-secondary border form-control">Quay lại</a>
                    </div>
                </div>
            </form>
        </div>
    </div>
</div>
